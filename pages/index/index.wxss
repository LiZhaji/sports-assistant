.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.calendar-container {
  background-color: #fff;
  border-radius: 20rpx;
  margin-bottom: 40rpx;
  padding: 20rpx;
}

.plans-container {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333;
}

.plan-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.plan-item:last-child {
  border-bottom: none;
}

.plan-info {
  flex: 1;
}

.plan-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.plan-time {
  font-size: 24rpx;
  color: #999;
}

.plan-status {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.status-completed {
  color: #4caf50;
}

.status-pending {
  color: #ff9800;
}

.no-plans {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
}