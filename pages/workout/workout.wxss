.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.workout-info {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

.workout-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.workout-type {
  font-size: 28rpx;
  color: #999;
}

.media-player {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

.media-cover {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.media-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  display: block;
}

.player-controls {
  margin-bottom: 30rpx;
}

.control-btn {
  margin: 0 20rpx 20rpx;
}

.progress-container {
  margin-top: 20rpx;
}

.progress-bar {
  width: 100%;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
  text-align: center;
}

.running-mode {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.running-info {
  text-align: center;
  margin-bottom: 40rpx;
}

.target-info {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.distance-info {
  display: block;
  font-size: 28rpx;
  color: #4CAF50;
  margin-bottom: 10rpx;
}

.time-info {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.running-controls {
  display: flex;
  justify-content: space-around;
}

.bottom-controls {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx;
  display: flex;
  justify-content: space-around;
  border-top: 1rpx solid #eee;
}

.bottom-controls .control-btn {
  flex: 1;
  margin: 0 20rpx;
}