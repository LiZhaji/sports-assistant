.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.media-preview {
  display: flex;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin: 20rpx 0;
  align-items: center;
}

.media-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
}

.media-info {
  flex: 1;
}

.media-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.media-duration {
  font-size: 24rpx;
  color: #999;
}

.button-container {
  padding: 40rpx 20rpx;
}

.button-container .van-button {
  border-radius: 20rpx;
}